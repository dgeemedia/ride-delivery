# mobile/.env.example
# Copy this file to .env and fill in your real keys.
# .env is gitignored — never commit real keys.

GOOGLE_MAPS_API_KEY_ANDROID=your_android_google_maps_key_here
GOOGLE_MAPS_API_KEY_IOS=your_ios_google_maps_key_here

# Optional — overrides the default dev server URL
# API_URL=http://192.168.21.189:3000/api
