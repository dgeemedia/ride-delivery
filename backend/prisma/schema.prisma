generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                   String                  @id @default(dbgenerated("(gen_random_uuid())::text"))
  email                String                  @unique
  phone                String                  @unique
  password             String
  firstName            String
  lastName             String
  role                 UserRole                @default(CUSTOMER)
  profileImage         String?
  isVerified           Boolean                 @default(false)
  isActive             Boolean                 @default(true)
  isSuspended          Boolean                 @default(false)
  suspendedAt          DateTime?
  suspendedBy          String?
  suspensionReason     String?
  passwordResetToken   String?
  passwordResetExpires DateTime?
  emailVerifyToken     String?
  emailVerifyExpires   DateTime?
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @default(now()) @updatedAt
  adminDepartment      String?
  twoFactorEnabled     Boolean                 @default(false)
  twoFactorMethod      String?
  activityLogs         ActivityLog[]
  adminProfile         AdminProfile?
  appFeedback          AppFeedback[]
  commissions          CommissionLedger[]      @relation("CommissionEarner")
  company              Company?                @relation("CompanyAdmin")
  companyEmployments   CompanyEmployee[]       @relation("CompanyEmployees")
  customerDeliveries   Delivery[]              @relation("CustomerDeliveries")
  partnerDeliveries    Delivery[]              @relation("PartnerDeliveries")
  deliveryProfile      DeliveryPartnerProfile?
  driverProfile        DriverProfile?
  duoPayAccount        DuoPayAccount?
  notifications        Notification[]
  otpVerifications     OtpVerification[]
  payments             Payment[]
  payouts              Payout[]
  ratings              Rating[]
  customerRides        Ride[]                  @relation("CustomerRides")
  driverRides          Ride[]                  @relation("DriverRides")
  shieldBeneficiaries  ShieldBeneficiary[]
  shieldSessions       ShieldSession[]
  supportTickets       SupportTicket[]
  ticketReplies        TicketReply[]           @relation("TicketReplyAuthor")
  receivedTransfers    Transfer[]              @relation("ReceivedTransfers")
  sentTransfers        Transfer[]              @relation("SentTransfers")
  wallet               Wallet?

  @@index([email])
  @@index([phone])
  @@index([role])
  @@index([isActive])
  @@index([adminDepartment])
}

model OtpVerification {
  id        String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId    String
  code      String
  purpose   String
  tempToken String   @unique
  attempts  Int      @default(0)
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tempToken])
  @@index([userId])
  @@index([expiresAt])
}

model DriverProfile {
  id                  String      @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId              String      @unique
  licenseNumber       String      @unique
  vehicleType         VehicleType
  vehicleMake         String
  vehicleModel        String
  vehicleYear         Int
  vehicleColor        String
  vehiclePlate        String      @unique
  isApproved          Boolean     @default(false)
  isOnline            Boolean     @default(false)
  currentLat          Float?
  currentLng          Float?
  totalRides          Int         @default(0)
  rating              Float       @default(0)
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @default(now()) @updatedAt
  preferredFloorPrice Float?
  insuranceUrl        String?     @map("insurance_url")
  licenseImageUrl     String?     @map("license_image_url")
  vehicleRegUrl       String?     @map("vehicle_reg_url")
  approvedAt          DateTime?
  approvedBy          String?
  documentsUploadedAt DateTime?
  isRejected          Boolean     @default(false)
  rejectedAt          DateTime?
  rejectedBy          String?
  rejectionReason     String?
  user                User        @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([isApproved])
  @@index([isRejected])
  @@index([isOnline, currentLat, currentLng])
}

model DeliveryPartnerProfile {
  id                  String      @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId              String      @unique
  vehicleType         VehicleType
  vehiclePlate        String?
  idImageUrl          String?
  vehicleImageUrl     String?
  isApproved          Boolean     @default(false)
  isRejected          Boolean     @default(false)       // ← NEW
  isOnline            Boolean     @default(false)
  currentLat          Float?
  currentLng          Float?
  totalDeliveries     Int         @default(0)
  rating              Float       @default(0)
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @default(now()) @updatedAt
  preferredFloorPrice Float?
  approvedAt          DateTime?                         // ← NEW
  approvedBy          String?                           // ← NEW
  rejectedAt          DateTime?                         // ← NEW
  rejectedBy          String?                           // ← NEW
  rejectionReason     String?                           // ← NEW
  documentsUploadedAt DateTime?                         // ← NEW
  user                User        @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([isApproved])
  @@index([isRejected])                                 // ← NEW
  @@index([isOnline, currentLat, currentLng])
}

model Ride {
  id                 String             @id @default(dbgenerated("(gen_random_uuid())::text"))
  customerId         String
  driverId           String?
  pickupAddress      String
  pickupLat          Float
  pickupLng          Float
  dropoffAddress     String
  dropoffLat         Float
  dropoffLng         Float
  status             RideStatus         @default(REQUESTED)
  distance           Float?
  duration           Int?
  estimatedFare      Float
  actualFare         Float?
  promoCode          String?
  requestedAt        DateTime           @default(now())
  acceptedAt         DateTime?
  arrivedAt          DateTime?
  startedAt          DateTime?
  completedAt        DateTime?
  cancelledAt        DateTime?
  notes              String?
  cancellationReason String?
  isCorporate        Boolean            @default(false)
  corporateTrip      CorporateTrip?
  duoPayTransaction  DuoPayTransaction?
  payment            Payment?
  rating             Rating?
  customer           User               @relation("CustomerRides", fields: [customerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  driver             User?              @relation("DriverRides", fields: [driverId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  shieldSession      ShieldSession?

  @@index([customerId])
  @@index([driverId])
  @@index([status])
  @@index([requestedAt])
  @@index([isCorporate])
}

model Delivery {
  id                 String         @id @default(dbgenerated("(gen_random_uuid())::text"))
  customerId         String
  partnerId          String?
  pickupAddress      String
  pickupLat          Float
  pickupLng          Float
  pickupContact      String
  dropoffAddress     String
  dropoffLat         Float
  dropoffLng         Float
  dropoffContact     String
  packageDescription String
  packageWeight      Float?
  packageValue       Float?
  status             DeliveryStatus @default(PENDING)
  distance           Float?
  estimatedFee       Float
  actualFee          Float?
  deliveryImageUrl   String?
  recipientName      String?
  recipientSignature String?
  promoCode          String?
  requestedAt        DateTime       @default(now())
  assignedAt         DateTime?
  pickedUpAt         DateTime?
  deliveredAt        DateTime?
  cancelledAt        DateTime?
  notes              String?
  cancellationReason String?
  inTransitAt        DateTime?      @db.Timestamptz(6)
  isCorporate        Boolean        @default(false)
  corporateTrip      CorporateTrip?
  customer           User           @relation("CustomerDeliveries", fields: [customerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  partner            User?          @relation("PartnerDeliveries", fields: [partnerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  payment            Payment?
  rating             Rating?
  shieldSession      ShieldSession?

  @@index([customerId])
  @@index([partnerId])
  @@index([status])
  @@index([requestedAt])
  @@index([isCorporate])
}

model Payment {
  id               String            @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId           String
  rideId           String?           @unique
  deliveryId       String?           @unique
  amount           Float
  currency         String            @default("NGN")
  method           PaymentMethod
  status           PaymentStatus     @default(PENDING)
  transactionId    String?           @unique
  receiptUrl       String?
  platformFee      Float?
  driverEarnings   Float?
  refundAmount     Float?
  refundedAt       DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @default(now()) @updatedAt
  commissionLedger CommissionLedger?
  delivery         Delivery?         @relation(fields: [deliveryId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  ride             Ride?             @relation(fields: [rideId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user             User              @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([userId])
  @@index([status])
}

model Rating {
  id         String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId     String
  rideId     String?   @unique
  deliveryId String?   @unique
  rating     Int
  comment    String?
  createdAt  DateTime  @default(now())
  delivery   Delivery? @relation(fields: [deliveryId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  ride       Ride?     @relation(fields: [rideId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user       User      @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([userId])
}

model Wallet {
  id           String              @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId       String              @unique
  balance      Float               @default(0)
  currency     String              @default("NGN")
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @default(now()) @updatedAt
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  transactions WalletTransaction[]

  @@index([userId])
}

model WalletTransaction {
  id          String       @id @default(dbgenerated("(gen_random_uuid())::text"))
  walletId    String
  type        WalletTxType
  amount      Float
  description String
  status      String       @default("COMPLETED")
  reference   String?      @unique
  createdAt   DateTime     @default(now())
  wallet      Wallet       @relation(fields: [walletId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([walletId])
  @@index([type])
  @@index([createdAt])
}

model Payout {
  id            String       @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId        String
  amount        Float
  currency      String       @default("NGN")
  status        PayoutStatus @default(PENDING)
  accountNumber String
  bankCode      String
  accountName   String
  reference     String?      @unique
  recipientCode String?
  transferCode  String?
  transferError String?
  processedAt   DateTime?
  failureReason String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @default(now()) @updatedAt
  user          User         @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([userId])
  @@index([status])
}

model Transfer {
  id          String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  reference   String   @unique
  senderId    String
  recipientId String
  amount      Float
  note        String?
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
  recipient   User     @relation("ReceivedTransfers", fields: [recipientId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  sender      User     @relation("SentTransfers", fields: [senderId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([senderId])
  @@index([recipientId])
  @@index([status])
  @@index([createdAt])
}

model AdminProfile {
  id          String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId      String    @unique
  permissions Json
  department  String?
  lastLoginAt DateTime?
  loginCount  Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now()) @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId])
}

model Notification {
  id        String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId    String
  title     String
  message   String
  type      String
  data      Json?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

model ActivityLog {
  id         String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId     String?
  action     String
  entityType String
  entityId   String?
  details    Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id], onUpdate: NoAction)

  @@index([userId])
  @@index([action])
  @@index([entityType])
  @@index([createdAt])
}

model SystemSettings {
  id          String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  key         String   @unique
  value       Json
  category    String
  description String?
  updatedBy   String?
  updatedAt   DateTime @default(now()) @updatedAt
  createdAt   DateTime @default(now())

  @@index([category])
}

model PromoCode {
  id                String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  code              String   @unique
  description       String?
  discountType      String
  discountValue     Float
  maxUses           Int?
  currentUses       Int      @default(0)
  maxUsesPerUser    Int      @default(1)
  minPurchaseAmount Float?
  validFrom         DateTime
  validUntil        DateTime
  isActive          Boolean  @default(true)
  applicableFor     String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @default(now()) @updatedAt

  @@index([code])
  @@index([isActive])
}

model SupportTicket {
  id           String        @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId       String
  ticketNumber String        @unique
  subject      String
  description  String
  category     String
  priority     String        @default("medium")
  status       String        @default("open")
  assignedTo   String?
  resolvedAt   DateTime?
  resolution   String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @default(now()) @updatedAt
  user         User          @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  replies      TicketReply[]

  @@index([userId])
  @@index([status])
  @@index([priority])
  @@index([assignedTo])
  @@index([createdAt])
}

model TicketReply {
  id        String        @id @default(dbgenerated("(gen_random_uuid())::text"))
  ticketId  String
  authorId  String
  message   String
  isAdmin   Boolean       @default(true)
  createdAt DateTime      @default(now()) @db.Timestamptz(6)
  author    User          @relation("TicketReplyAuthor", fields: [authorId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([ticketId])
  @@index([authorId])
}

model AppFeedback {
  id         String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId     String
  rating     Int
  comment    String?
  category   String
  platform   String
  appVersion String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([userId])
  @@index([rating])
  @@index([createdAt])
}

model CommissionLedger {
  id               String   @id @default(uuid())
  paymentId        String   @unique
  serviceType      String
  rideId           String?
  deliveryId       String?
  earnerUserId     String
  grossAmount      Float
  bookingFee       Float    @default(0)
  commissionRate   Float
  commissionAmount Float
  earnerAmount     Float
  surgeMultiplier  Float    @default(1.0)
  currency         String   @default("NGN")
  createdAt        DateTime @default(now())
  earnerUser       User     @relation("CommissionEarner", fields: [earnerUserId], references: [id])
  payment          Payment  @relation(fields: [paymentId], references: [id])

  @@index([serviceType])
  @@index([earnerUserId])
  @@index([createdAt])
}

model ShieldBeneficiary {
  id        String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId    String
  name      String
  phone     String
  email     String?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @db.Timestamptz(6)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId])
}

model ShieldSession {
  id               String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  token            String    @unique
  userId           String
  rideId           String?   @unique
  deliveryId       String?   @unique
  beneficiaryPhone String?
  beneficiaryName  String?
  beneficiaryEmail String?
  isActive         Boolean   @default(true)
  viewCount        Int       @default(0)
  autoTriggered    Boolean   @default(false)
  driverAlerted    Boolean   @default(false)
  arrivedSafe      Boolean   @default(false)
  lastPingAt       DateTime? @db.Timestamptz(6)
  expiresAt        DateTime  @db.Timestamptz(6)
  createdAt        DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime  @default(now()) @updatedAt @db.Timestamptz(6)
  delivery         Delivery? @relation(fields: [deliveryId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  ride             Ride?     @relation(fields: [rideId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([token])
  @@index([userId])
  @@index([isActive])
  @@index([expiresAt])
}

model Company {
  id                String            @id @default(dbgenerated("(gen_random_uuid())::text"))
  name              String
  rcNumber          String?           @unique
  email             String            @unique
  phone             String
  address           String?
  logoUrl           String?
  adminUserId       String            @unique
  billingType       BillingType       @default(PREPAID)
  status            CompanyStatus     @default(PENDING)
  commissionRate    Float             @default(0.18)
  onboardingFeePaid Boolean           @default(false)
  onboardingPaidAt  DateTime?         @db.Timestamptz(6)
  monthlyMinimum    Float             @default(100000)
  createdAt         DateTime          @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime          @default(now()) @updatedAt @db.Timestamptz(6)
  admin             User              @relation("CompanyAdmin", fields: [adminUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  employees         CompanyEmployee[]
  wallet            CompanyWallet?
  trips             CorporateTrip[]

  @@index([status])
  @@index([adminUserId])
}

model CompanyWallet {
  id                  String                     @id @default(dbgenerated("(gen_random_uuid())::text"))
  companyId           String                     @unique(map: "CompanyWallet_unique")
  balance             Float                      @default(0)
  currency            String                     @default("NGN")
  lowBalanceThreshold Float                      @default(50000)
  createdAt           DateTime                   @default(now()) @db.Timestamptz(6)
  updatedAt           DateTime                   @default(now()) @updatedAt @db.Timestamptz(6)
  company             Company                    @relation(fields: [companyId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  transactions        CompanyWalletTransaction[]

  @@index([companyId])
}

model CompanyWalletTransaction {
  id          String        @id @default(dbgenerated("(gen_random_uuid())::text"))
  walletId    String
  type        String
  amount      Float
  description String
  reference   String?       @unique(map: "CompanyWalletTransaction_ref_key")
  status      String        @default("COMPLETED")
  createdAt   DateTime      @default(now()) @db.Timestamptz(6)
  wallet      CompanyWallet @relation(fields: [walletId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([createdAt], map: "CompanyWalletTx_createdAt_idx")
  @@index([walletId], map: "CompanyWalletTx_walletId_idx")
}

model CompanyEmployee {
  id                      String          @id @default(dbgenerated("(gen_random_uuid())::text"))
  companyId               String
  userId                  String
  monthlyLimit            Float           @default(30000)
  currentMonthSpend       Float           @default(0)
  spendResetDate          DateTime?       @db.Timestamptz(6)
  department              String?
  jobTitle                String?
  isActive                Boolean         @default(true)
  restrictToBusinessHours Boolean         @default(false)
  requireTripPurpose      Boolean         @default(false)
  inviteStatus            InviteStatus    @default(PENDING)
  invitedAt               DateTime        @default(now()) @db.Timestamptz(6)
  joinedAt                DateTime?       @db.Timestamptz(6)
  createdAt               DateTime        @default(now()) @db.Timestamptz(6)
  updatedAt               DateTime        @default(now()) @updatedAt @db.Timestamptz(6)
  company                 Company         @relation(fields: [companyId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user                    User            @relation("CompanyEmployees", fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  trips                   CorporateTrip[]

  @@unique([companyId, userId], map: "CompanyEmployee_unique")
  @@index([companyId])
  @@index([userId])
  @@index([inviteStatus], map: "CompanyEmployee_invite_idx")
}

model CorporateTrip {
  id               String          @id @default(dbgenerated("(gen_random_uuid())::text"))
  rideId           String?         @unique
  deliveryId       String?         @unique(map: "CorporateTrip_delId_key")
  companyId        String
  employeeId       String
  purpose          String?
  fare             Float
  commissionAmount Float
  billedAt         DateTime?       @db.Timestamptz(6)
  invoiceId        String?
  createdAt        DateTime        @default(now()) @db.Timestamptz(6)
  company          Company         @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  delivery         Delivery?       @relation(fields: [deliveryId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  employee         CompanyEmployee @relation(fields: [employeeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  ride             Ride?           @relation(fields: [rideId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([companyId])
  @@index([employeeId])
  @@index([createdAt])
}

model DuoPayAccount {
  id                       String              @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId                   String              @unique
  creditLimit              Float               @default(2000)
  usedBalance              Float               @default(0)
  status                   DuoPayStatus        @default(INACTIVE)
  repaymentDay             Int                 @default(1)
  consecutiveOnTime        Int                 @default(0)
  paystackSubscriptionCode String?
  paystackCustomerCode     String?
  cardLast4                String?
  cardBrand                String?
  activatedAt              DateTime?           @db.Timestamptz(6)
  suspendedAt              DateTime?           @db.Timestamptz(6)
  nextRepaymentDate        DateTime?           @db.Timestamptz(6)
  createdAt                DateTime            @default(now()) @db.Timestamptz(6)
  updatedAt                DateTime            @default(now()) @updatedAt @db.Timestamptz(6)
  user                     User                @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  transactions             DuoPayTransaction[]

  @@index([userId])
  @@index([status])
  @@index([nextRepaymentDate], map: "DuoPayAccount_repaymentDate_idx")
}

model DuoPayTransaction {
  id                 String         @id @default(dbgenerated("(gen_random_uuid())::text"))
  duoPayAccountId    String
  rideId             String?        @unique
  amount             Float
  dueDate            DateTime       @db.Timestamptz(6)
  paidAt             DateTime?      @db.Timestamptz(6)
  status             DuoPayTxStatus @default(PENDING)
  repaymentReference String?        @unique(map: "DuoPayTransaction_ref_key")
  reminderSentAt     DateTime?      @db.Timestamptz(6)
  createdAt          DateTime       @default(now()) @db.Timestamptz(6)
  updatedAt          DateTime       @default(now()) @updatedAt @db.Timestamptz(6)
  account            DuoPayAccount  @relation(fields: [duoPayAccountId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "DuoPayTransaction_accountId_fkey")
  ride               Ride?          @relation(fields: [rideId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([duoPayAccountId], map: "DuoPayTx_accountId_idx")
  @@index([dueDate], map: "DuoPayTx_dueDate_idx")
  @@index([status], map: "DuoPayTx_status_idx")
}

enum UserRole {
  CUSTOMER
  DRIVER
  DELIVERY_PARTNER
