generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                   String                  @id @default(dbgenerated("(gen_random_uuid())::text"))
  email                String                  @unique
  phone                String                  @unique
  password             String
  firstName            String
  lastName             String
  role                 UserRole                @default(CUSTOMER)
  profileImage         String?
  isVerified           Boolean                 @default(false)
  isActive             Boolean                 @default(true)
  isSuspended          Boolean                 @default(false)
  suspendedAt          DateTime?
  suspendedBy          String?
  suspensionReason     String?
  passwordResetToken   String?
  passwordResetExpires DateTime?
  emailVerifyToken     String?
  emailVerifyExpires   DateTime?
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @default(now()) @updatedAt
  adminDepartment      String?
  activityLogs         ActivityLog[]
  adminProfile         AdminProfile?
  appFeedback          AppFeedback[]
  customerDeliveries   Delivery[]              @relation("CustomerDeliveries")
  partnerDeliveries    Delivery[]              @relation("PartnerDeliveries")
  deliveryProfile      DeliveryPartnerProfile?
  driverProfile        DriverProfile?
  notifications        Notification[]
  payments             Payment[]
  payouts              Payout[]
  ratings              Rating[]
  customerRides        Ride[]                  @relation("CustomerRides")
  driverRides          Ride[]                  @relation("DriverRides")
  supportTickets       SupportTicket[]
  ticketReplies        TicketReply[]           @relation("TicketReplyAuthor")
  wallet               Wallet?
  // ── SHIELD ──────────────────────────────────────
  shieldBeneficiaries  ShieldBeneficiary[]
  shieldSessions       ShieldSession[]
  // ── CORPORATE ───────────────────────────────────
  company              Company?                @relation("CompanyAdmin")
  companyEmployments   CompanyEmployee[]       @relation("CompanyEmployees")
  // ── DUOPAY ──────────────────────────────────────
  duoPayAccount        DuoPayAccount?

  @@index([email])
  @@index([phone])
  @@index([role])
  @@index([isActive])
  @@index([adminDepartment])
}

model DriverProfile {
  id                  String      @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId              String      @unique
  licenseNumber       String      @unique
  vehicleType         VehicleType
  vehicleMake         String
  vehicleModel        String
  vehicleYear         Int
  vehicleColor        String
  vehiclePlate        String      @unique
  licenseImageUrl     String?
  vehicleRegUrl       String?
  insuranceUrl        String?
  isApproved          Boolean     @default(false)
  isOnline            Boolean     @default(false)
  currentLat          Float?
  currentLng          Float?
  totalRides          Int         @default(0)
  rating              Float       @default(0)
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @default(now()) @updatedAt
  preferredFloorPrice Float?
  user                User        @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([isApproved])
  @@index([isOnline, currentLat, currentLng])
}

model DeliveryPartnerProfile {
  id                  String      @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId              String      @unique
  vehicleType         VehicleType
  vehiclePlate        String?
  idImageUrl          String?
  vehicleImageUrl     String?
  isApproved          Boolean     @default(false)
  isOnline            Boolean     @default(false)
  currentLat          Float?
  currentLng          Float?
  totalDeliveries     Int         @default(0)
  rating              Float       @default(0)
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @default(now()) @updatedAt
  preferredFloorPrice Float?
  user                User        @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([isApproved])
  @@index([isOnline, currentLat, currentLng])
}

model Ride {
  id                 String         @id @default(dbgenerated("(gen_random_uuid())::text"))
  customerId         String
  driverId           String?
  pickupAddress      String
  pickupLat          Float
  pickupLng          Float
  dropoffAddress     String
  dropoffLat         Float
  dropoffLng         Float
  status             RideStatus     @default(REQUESTED)
  distance           Float?
  duration           Int?
  estimatedFare      Float
  actualFare         Float?
  promoCode          String?
  requestedAt        DateTime       @default(now())
  acceptedAt         DateTime?
  arrivedAt          DateTime?
  startedAt          DateTime?
  completedAt        DateTime?
  cancelledAt        DateTime?
  notes              String?
  cancellationReason String?
  // ── CORPORATE ───────────────────────────────────
  isCorporate        Boolean        @default(false)
  corporateTrip      CorporateTrip?
  // ── SHIELD ──────────────────────────────────────
  shieldSession      ShieldSession?
  // ── DUOPAY ──────────────────────────────────────
  duoPayTransaction  DuoPayTransaction?
  payment            Payment?
  rating             Rating?
  customer           User           @relation("CustomerRides", fields: [customerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  driver             User?          @relation("DriverRides", fields: [driverId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([customerId])
  @@index([driverId])
  @@index([status])
  @@index([requestedAt])
  @@index([isCorporate])
}

model Delivery {
  id                 String         @id @default(dbgenerated("(gen_random_uuid())::text"))
  customerId         String
  partnerId          String?
  pickupAddress      String
  pickupLat          Float
  pickupLng          Float
  pickupContact      String
  dropoffAddress     String
  dropoffLat         Float
  dropoffLng         Float
  dropoffContact     String
  packageDescription String
  packageWeight      Float?
  packageValue       Float?
  status             DeliveryStatus @default(PENDING)
  distance           Float?
  estimatedFee       Float
  actualFee          Float?
  deliveryImageUrl   String?
  recipientName      String?
  recipientSignature String?
  promoCode          String?
  requestedAt        DateTime       @default(now())
  assignedAt         DateTime?
  pickedUpAt         DateTime?
  deliveredAt        DateTime?
  cancelledAt        DateTime?
  notes              String?
  cancellationReason String?
  inTransitAt        DateTime?      @db.Timestamptz(6)
  // ── CORPORATE ───────────────────────────────────
  isCorporate        Boolean        @default(false)
  corporateTrip      CorporateTrip?
  // ── SHIELD ──────────────────────────────────────
  shieldSession      ShieldSession?
  customer           User           @relation("CustomerDeliveries", fields: [customerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  partner            User?          @relation("PartnerDeliveries", fields: [partnerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  payment            Payment?
  rating             Rating?

  @@index([customerId])
  @@index([partnerId])
  @@index([status])
  @@index([requestedAt])
}

model Payment {
  id             String        @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId         String
  rideId         String?       @unique
  deliveryId     String?       @unique
  amount         Float
  currency       String        @default("NGN")
  method         PaymentMethod
  status         PaymentStatus @default(PENDING)
  transactionId  String?       @unique
  receiptUrl     String?
  platformFee    Float?
  driverEarnings Float?
  refundAmount   Float?
  refundedAt     DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @default(now()) @updatedAt
  delivery       Delivery?     @relation(fields: [deliveryId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  ride           Ride?         @relation(fields: [rideId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user           User          @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([userId])
  @@index([status])
}

model Rating {
  id         String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId     String
  rideId     String?   @unique
  deliveryId String?   @unique
  rating     Int
  comment    String?
  createdAt  DateTime  @default(now())
  delivery   Delivery? @relation(fields: [deliveryId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  ride       Ride?     @relation(fields: [rideId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user       User      @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([userId])
}

model Wallet {
  id           String              @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId       String              @unique
  balance      Float               @default(0)
  currency     String              @default("NGN")
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @default(now()) @updatedAt
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  transactions WalletTransaction[]

  @@index([userId])
}

model WalletTransaction {
  id          String       @id @default(dbgenerated("(gen_random_uuid())::text"))
  walletId    String
  type        WalletTxType
  amount      Float
  description String
  status      String       @default("COMPLETED")
  reference   String?      @unique
  createdAt   DateTime     @default(now())
  wallet      Wallet       @relation(fields: [walletId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([walletId])
  @@index([type])
  @@index([createdAt])
}

model Payout {
  id            String       @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId        String
  amount        Float
  currency      String       @default("NGN")
  status        PayoutStatus @default(PENDING)
  accountNumber String
  bankCode      String
  accountName   String
  reference     String?      @unique
  recipientCode String?
  processedAt   DateTime?
  failureReason String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @default(now()) @updatedAt
  user          User         @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([userId])
  @@index([status])
}

model AdminProfile {
  id          String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId      String    @unique
  permissions Json
  department  String?
  lastLoginAt DateTime?
  loginCount  Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now()) @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId])
}

model Notification {
  id        String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId    String
  title     String
  message   String
  type      String
  data      Json?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

model ActivityLog {
  id         String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId     String?
  action     String
  entityType String
  entityId   String?
  details    Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id], onUpdate: NoAction)

  @@index([userId])
  @@index([action])
  @@index([entityType])
  @@index([createdAt])
}

model SystemSettings {
  id          String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  key         String   @unique
  value       Json
  category    String
  description String?
  updatedBy   String?
  updatedAt   DateTime @default(now()) @updatedAt
  createdAt   DateTime @default(now())

  @@index([category])
}

model PromoCode {
  id                String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  code              String   @unique
  description       String?
  discountType      String
  discountValue     Float
  maxUses           Int?
  currentUses       Int      @default(0)
  maxUsesPerUser    Int      @default(1)
  minPurchaseAmount Float?
  validFrom         DateTime
  validUntil        DateTime
  isActive          Boolean  @default(true)
  applicableFor     String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @default(now()) @updatedAt

  @@index([code])
  @@index([isActive])
}

model SupportTicket {
  id           String        @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId       String
  ticketNumber String        @unique
  subject      String
  description  String
  category     String
  priority     String        @default("medium")
  status       String        @default("open")
  assignedTo   String?
  resolvedAt   DateTime?
  resolution   String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @default(now()) @updatedAt
  user         User          @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  replies      TicketReply[]

  @@index([userId])
  @@index([status])
  @@index([priority])
  @@index([assignedTo])
  @@index([createdAt])
}

model TicketReply {
  id        String        @id @default(dbgenerated("(gen_random_uuid())::text"))
  ticketId  String
  authorId  String
  message   String
  isAdmin   Boolean       @default(true)
  createdAt DateTime      @default(now()) @db.Timestamptz(6)
  author    User          @relation("TicketReplyAuthor", fields: [authorId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([ticketId])
  @@index([authorId])
}

model AppFeedback {
  id         String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId     String
  rating     Int
  comment    String?
  category   String
  platform   String
  appVersion String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([userId])
  @@index([rating])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// SHIELD — Safety Guardian Feature
// ─────────────────────────────────────────────────────────────────────────────

model ShieldBeneficiary {
  id        String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId    String
  name      String
  phone     String
  email     String?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ShieldSession {
  id               String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  token            String    @unique
  userId           String
  rideId           String?   @unique
  deliveryId       String?   @unique
  beneficiaryPhone String?
  beneficiaryName  String?
  beneficiaryEmail String?
  isActive         Boolean   @default(true)
  viewCount        Int       @default(0)
  autoTriggered    Boolean   @default(false)
  driverAlerted    Boolean   @default(false)
  arrivedSafe      Boolean   @default(false)
  lastPingAt       DateTime?
  expiresAt        DateTime
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @default(now()) @updatedAt
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  ride             Ride?     @relation(fields: [rideId], references: [id], onDelete: NoAction)
  delivery         Delivery? @relation(fields: [deliveryId], references: [id], onDelete: NoAction)

  @@index([token])
  @@index([userId])
  @@index([isActive])
  @@index([expiresAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// CORPORATE ACCOUNTS
// ─────────────────────────────────────────────────────────────────────────────

model Company {
  id                 String            @id @default(dbgenerated("(gen_random_uuid())::text"))
  name               String
  rcNumber           String?           @unique
  email              String            @unique
  phone              String
  address            String?
  logoUrl            String?
  adminUserId        String            @unique
  billingType        BillingType       @default(PREPAID)
  status             CompanyStatus     @default(PENDING)
  commissionRate     Float             @default(0.18)
  onboardingFeePaid  Boolean           @default(false)
  onboardingPaidAt   DateTime?
  monthlyMinimum     Float             @default(100000)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @default(now()) @updatedAt
  admin              User              @relation("CompanyAdmin", fields: [adminUserId], references: [id], onDelete: NoAction)
  wallet             CompanyWallet?
  employees          CompanyEmployee[]
  trips              CorporateTrip[]

  @@index([status])
  @@index([adminUserId])
}

model CompanyWallet {
  id                   String                     @id @default(dbgenerated("(gen_random_uuid())::text"))
  companyId            String                     @unique
  balance              Float                      @default(0)
  currency             String                     @default("NGN")
  lowBalanceThreshold  Float                      @default(50000)
  createdAt            DateTime                   @default(now())
  updatedAt            DateTime                   @default(now()) @updatedAt
  company              Company                    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  transactions         CompanyWalletTransaction[]

  @@index([companyId])
}

model CompanyWalletTransaction {
  id          String        @id @default(dbgenerated("(gen_random_uuid())::text"))
  walletId    String
  type        String
  amount      Float
  description String
  reference   String?       @unique
  status      String        @default("COMPLETED")
  createdAt   DateTime      @default(now())
  wallet      CompanyWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId])
  @@index([createdAt])
}

model CompanyEmployee {
  id                       String        @id @default(dbgenerated("(gen_random_uuid())::text"))
  companyId                String
  userId                   String
  monthlyLimit             Float         @default(30000)
  currentMonthSpend        Float         @default(0)
  spendResetDate           DateTime?
  department               String?
  jobTitle                 String?
  isActive                 Boolean       @default(true)
  restrictToBusinessHours  Boolean       @default(false)
  requireTripPurpose       Boolean       @default(false)
  inviteStatus             InviteStatus  @default(PENDING)
  invitedAt                DateTime      @default(now())
  joinedAt                 DateTime?
  createdAt                DateTime      @default(now())
  updatedAt                DateTime      @default(now()) @updatedAt
  company                  Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user                     User          @relation("CompanyEmployees", fields: [userId], references: [id], onDelete: NoAction)
  trips                    CorporateTrip[]

  @@unique([companyId, userId])
  @@index([companyId])
  @@index([userId])
  @@index([inviteStatus])
}

model CorporateTrip {
  id               String          @id @default(dbgenerated("(gen_random_uuid())::text"))
  rideId           String?         @unique
  deliveryId       String?         @unique
  companyId        String
  employeeId       String
  purpose          String?
  fare             Float
  commissionAmount Float
  billedAt         DateTime?
  invoiceId        String?
  createdAt        DateTime        @default(now())
  company          Company         @relation(fields: [companyId], references: [id], onDelete: NoAction)
  employee         CompanyEmployee @relation(fields: [employeeId], references: [id], onDelete: NoAction)
  ride             Ride?           @relation(fields: [rideId], references: [id], onDelete: NoAction)
  delivery         Delivery?       @relation(fields: [deliveryId], references: [id], onDelete: NoAction)

  @@index([companyId])
  @@index([employeeId])
  @@index([createdAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// DUOPAY — Ride Now, Pay Later
// ─────────────────────────────────────────────────────────────────────────────

model DuoPayAccount {
  id                       String              @id @default(dbgenerated("(gen_random_uuid())::text"))
  userId                   String              @unique
  creditLimit              Float               @default(2000)
  usedBalance              Float               @default(0)
  status                   DuoPayStatus        @default(INACTIVE)
  repaymentDay             Int                 @default(1)
  consecutiveOnTime        Int                 @default(0)
  paystackSubscriptionCode String?
  paystackCustomerCode     String?
  cardLast4                String?
  cardBrand                String?
  activatedAt              DateTime?
  suspendedAt              DateTime?
  nextRepaymentDate        DateTime?
  createdAt                DateTime            @default(now())
  updatedAt                DateTime            @default(now()) @updatedAt
  user                     User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions             DuoPayTransaction[]

  @@index([userId])
  @@index([status])
  @@index([nextRepaymentDate])
}

model DuoPayTransaction {
  id                 String           @id @default(dbgenerated("(gen_random_uuid())::text"))
  duoPayAccountId    String
  rideId             String?          @unique
  amount             Float
  dueDate            DateTime
  paidAt             DateTime?
  status             DuoPayTxStatus   @default(PENDING)
  repaymentReference String?          @unique
  reminderSentAt     DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @default(now()) @updatedAt
  account            DuoPayAccount    @relation(fields: [duoPayAccountId], references: [id], onDelete: Cascade)
  ride               Ride?            @relation(fields: [rideId], references: [id], onDelete: NoAction)

  @@index([duoPayAccountId])
  @@index([status])
  @@index([dueDate])
}

// ─────────────────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────────────────

enum UserRole {
  CUSTOMER
  DRIVER
  DELIVERY_PARTNER
  ADMIN
  SUPER_ADMIN
  MODERATOR
  SUPPORT
}

enum ServiceType {
  RIDE
  DELIVERY
}

enum RideStatus {
  REQUESTED
  ACCEPTED
  ARRIVED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum DeliveryStatus {
  PENDING
  ASSIGNED
  PICKED_UP
  IN_TRANSIT
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum PaymentMethod {
  CASH
  CARD
  WALLET
  CORPORATE
  DUOPAY
}

enum VehicleType {
  BIKE
  CAR
  MOTORCYCLE
  VAN
}

enum WalletTxType {
  CREDIT
  DEBIT
  WITHDRAWAL
  REFUND
}

enum PayoutStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum BillingType {
  PREPAID
  POSTPAID
}

enum CompanyStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

enum InviteStatus {
  PENDING
  ACTIVE
  REJECTED
}

enum DuoPayStatus {
  INACTIVE
  ACTIVE
  SUSPENDED
  DEFAULTED
}

enum DuoPayTxStatus {
  PENDING
  PAID
  OVERDUE
  WAIVED
}
