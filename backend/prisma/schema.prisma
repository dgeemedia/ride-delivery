// This is your Prisma schema file
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enhanced with Admin features and audit trails

enum UserRole {
  CUSTOMER
  DRIVER
  DELIVERY_PARTNER
  ADMIN
  SUPER_ADMIN
  MODERATOR
  SUPPORT
}

enum ServiceType {
  RIDE
  DELIVERY
}

enum RideStatus {
  REQUESTED
  ACCEPTED
  ARRIVED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum DeliveryStatus {
  PENDING
  ASSIGNED
  PICKED_UP
  IN_TRANSIT
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum PaymentMethod {
  CASH
  CARD
  WALLET
}

enum VehicleType {
  BIKE
  CAR
  MOTORCYCLE
  VAN
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  phone         String   @unique
  password      String
  firstName     String
  lastName      String
  role          UserRole @default(CUSTOMER)
  profileImage  String?
  isVerified    Boolean  @default(false)
  isActive      Boolean  @default(true)
  isSuspended   Boolean  @default(false)
  suspendedAt   DateTime?
  suspendedBy   String?
  suspensionReason String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  customerRides    Ride[]           @relation("CustomerRides")
  driverRides      Ride[]           @relation("DriverRides")
  customerDeliveries Delivery[]     @relation("CustomerDeliveries")
  partnerDeliveries  Delivery[]     @relation("PartnerDeliveries")
  driverProfile    DriverProfile?
  deliveryProfile  DeliveryPartnerProfile?
  adminProfile     AdminProfile?
  payments         Payment[]
  ratings          Rating[]
  notifications    Notification[]
  activityLogs     ActivityLog[]
  
  @@index([email])
  @@index([phone])
  @@index([role])
  @@index([isActive])
}

model DriverProfile {
  id                String       @id @default(uuid())
  userId            String       @unique
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  licenseNumber     String       @unique
  vehicleType       VehicleType
  vehicleMake       String
  vehicleModel      String
  vehicleYear       Int
  vehicleColor      String
  vehiclePlate      String       @unique
  
  // Documents
  licenseImageUrl   String
  vehicleRegUrl     String
  insuranceUrl      String
  
  // Status
  isApproved        Boolean      @default(false)
  isOnline          Boolean      @default(false)
  currentLat        Float?
  currentLng        Float?
  
  // Stats
  totalRides        Int          @default(0)
  rating            Float        @default(0)
  
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  // FUTURE: Add driver earnings tracking
  // totalEarnings Decimal @default(0)
  // FUTURE: Add driver availability schedule
  // availabilitySchedule Json?
  
  @@index([isOnline, currentLat, currentLng])
}

model DeliveryPartnerProfile {
  id                String       @id @default(uuid())
  userId            String       @unique
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  vehicleType       VehicleType
  vehiclePlate      String?
  
  // Documents
  idImageUrl        String
  vehicleImageUrl   String?
  
  // Status
  isApproved        Boolean      @default(false)
  isOnline          Boolean      @default(false)
  currentLat        Float?
  currentLng        Float?
  
  // Stats
  totalDeliveries   Int          @default(0)
  rating            Float        @default(0)
  
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  // FUTURE: Add delivery capacity (multiple deliveries)
  // maxConcurrentDeliveries Int @default(1)
  
  @@index([isOnline, currentLat, currentLng])
}

model Ride {
  id                String       @id @default(uuid())
  
  // Participants
  customerId        String
  customer          User         @relation("CustomerRides", fields: [customerId], references: [id])
  driverId          String?
  driver            User?        @relation("DriverRides", fields: [driverId], references: [id])
  
  // Location details
  pickupAddress     String
  pickupLat         Float
  pickupLng         Float
  dropoffAddress    String
  dropoffLat        Float
  dropoffLng        Float
  
  // Trip details
  status            RideStatus   @default(REQUESTED)
  distance          Float?       // in kilometers
  duration          Int?         // in minutes
  estimatedFare     Float
  actualFare        Float?
  
  // Timestamps
  requestedAt       DateTime     @default(now())
  acceptedAt        DateTime?
  startedAt         DateTime?
  completedAt       DateTime?
  cancelledAt       DateTime?
  
  // Additional info
  notes             String?
  cancellationReason String?
  
  // Relations
  payment           Payment?
  rating            Rating?

  // FUTURE: Add scheduled rides
  // scheduledFor DateTime?
  // FUTURE: Add multi-stop support
  // stops Json[]
  // FUTURE: Add ride preferences
  // preferences Json?
  
  @@index([customerId])
  @@index([driverId])
  @@index([status])
  @@index([requestedAt])
}

model Delivery {
  id                String          @id @default(uuid())
  
  // Participants
  customerId        String
  customer          User            @relation("CustomerDeliveries", fields: [customerId], references: [id])
  partnerId         String?
  partner           User?           @relation("PartnerDeliveries", fields: [partnerId], references: [id])
  
  // Location details
  pickupAddress     String
  pickupLat         Float
  pickupLng         Float
  pickupContact     String
  dropoffAddress    String
  dropoffLat        Float
  dropoffLng        Float
  dropoffContact    String
  
  // Package details
  packageDescription String
  packageWeight     Float?         // in kg
  packageValue      Float?         // for insurance
  
  // Delivery details
  status            DeliveryStatus @default(PENDING)
  distance          Float?         // in kilometers
  estimatedFee      Float
  actualFee         Float?
  
  // Proof of delivery
  deliveryImageUrl  String?
  recipientName     String?
  recipientSignature String?
  
  // Timestamps
  requestedAt       DateTime       @default(now())
  assignedAt        DateTime?
  pickedUpAt        DateTime?
  deliveredAt       DateTime?
  cancelledAt       DateTime?
  
  // Additional info
  notes             String?
  cancellationReason String?
  
  // Relations
  payment           Payment?
  rating            Rating?

  // FUTURE: Add scheduled deliveries
  // scheduledPickup DateTime?
  // FUTURE: Add multiple package support
  // packages Json[]
  // FUTURE: Add special handling requirements
  // specialInstructions Json?
  
  @@index([customerId])
  @@index([partnerId])
  @@index([status])
  @@index([requestedAt])
}

model Payment {
  id                String         @id @default(uuid())
  
  userId            String
  user              User           @relation(fields: [userId], references: [id])
  
  // Service reference
  rideId            String?        @unique
  ride              Ride?          @relation(fields: [rideId], references: [id])
  deliveryId        String?        @unique
  delivery          Delivery?      @relation(fields: [deliveryId], references: [id])
  
  // Payment details
  amount            Float
  currency          String         @default("USD")
  method            PaymentMethod
  status            PaymentStatus  @default(PENDING)
  
  // Transaction info
  transactionId     String?        @unique
  receiptUrl        String?
  
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  // FUTURE: Add payment split for commissions
  // platformFee Decimal?
  // driverEarnings Decimal?
  // FUTURE: Add refund support
  // refundAmount Decimal?
  // refundedAt DateTime?
  
  @@index([userId])
  @@index([status])
}

model Rating {
  id                String         @id @default(uuid())
  
  userId            String
  user              User           @relation(fields: [userId], references: [id])
  
  // Service reference
  rideId            String?        @unique
  ride              Ride?          @relation(fields: [rideId], references: [id])
  deliveryId        String?        @unique
  delivery          Delivery?      @relation(fields: [deliveryId], references: [id])
  
  // Rating details
  rating            Int            // 1-5 stars
  comment           String?
  
  createdAt         DateTime       @default(now())

  // FUTURE: Add detailed rating categories
  // punctuality Int?
  // professionalism Int?
  // vehicleCondition Int?
  
  @@index([userId])
}

// NEW: Admin Profile Model
model AdminProfile {
  id                String       @id @default(uuid())
  userId            String       @unique
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  permissions       Json         // Store permissions as JSON
  department        String?
  lastLoginAt       DateTime?
  loginCount        Int          @default(0)
  
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  
  @@index([userId])
}

// NEW: Notification Model
model Notification {
  id            String       @id @default(uuid())
  userId        String
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  title         String
  message       String
  type          String       // ride_accepted, delivery_assigned, payment_received, etc.
  data          Json?        // Additional data
  isRead        Boolean      @default(false)
  
  createdAt     DateTime     @default(now())
  
  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

// NEW: Activity Log Model (for admin audit trail)
model ActivityLog {
  id            String       @id @default(uuid())
  userId        String?
  user          User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  action        String       // user_suspended, driver_approved, payment_refunded, etc.
  entityType    String       // User, Driver, Ride, Delivery, Payment
  entityId      String?
  details       Json?        // Additional details
  ipAddress     String?
  userAgent     String?
  
  createdAt     DateTime     @default(now())
  
  @@index([userId])
  @@index([action])
  @@index([entityType])
  @@index([createdAt])
}

// NEW: System Settings Model
model SystemSettings {
  id            String       @id @default(uuid())
  key           String       @unique
  value         Json
  category      String       // pricing, features, notifications, etc.
  description   String?
  
  updatedBy     String?
  updatedAt     DateTime     @updatedAt
  createdAt     DateTime     @default(now())
  
  @@index([category])
}

// NEW: Promo Code Model
model PromoCode {
  id                String       @id @default(uuid())
  code              String       @unique
  description       String?
  discountType      String       // percentage, fixed
  discountValue     Float
  maxUses           Int?
  currentUses       Int          @default(0)
  maxUsesPerUser    Int          @default(1)
  minPurchaseAmount Float?
  
  validFrom         DateTime
  validUntil        DateTime
  isActive          Boolean      @default(true)
  
  applicableFor     String       // rides, deliveries, both
  
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  
  @@index([code])
  @@index([isActive])
}

// NEW: Support Ticket Model
model SupportTicket {
  id            String       @id @default(uuid())
  userId        String
  ticketNumber  String       @unique
  
  subject       String
  description   String
  category      String       // account, payment, technical, other
  priority      String       @default("medium") // low, medium, high, urgent
  status        String       @default("open")    // open, in_progress, resolved, closed
  
  assignedTo    String?
  resolvedAt    DateTime?
  resolution    String?
  
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  
  @@index([userId])
  @@index([status])
  @@index([assignedTo])
}

// NEW: Feedback/Review Model (for app reviews)
model AppFeedback {
  id            String       @id @default(uuid())
  userId        String
  
  rating        Int          // 1-5 stars
  comment       String?
  category      String       // app_experience, driver_quality, pricing, other
  platform      String       // ios, android, web
  appVersion    String?
  
  createdAt     DateTime     @default(now())
  
  @@index([userId])
  @@index([rating])
  @@index([createdAt])
}

