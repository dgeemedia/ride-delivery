# Database
DATABASE_URL="postgresql://username:password@localhost:5432/duoride"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"

# Server
PORT=3000
NODE_ENV="development"

# Google Maps (Get from: https://console.cloud.google.com/)
GOOGLE_MAPS_API_KEY="your-google-maps-api-key"

# Payment Gateway (Choose one)
# Stripe (https://stripe.com/)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."

# OR Paystack (Popular in Africa - https://paystack.com/)
# PAYSTACK_SECRET_KEY="sk_test_..."
# PAYSTACK_PUBLIC_KEY="pk_test_..."

# File Upload (Optional - for production)
# AWS S3
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# AWS_REGION="us-east-1"
# AWS_BUCKET_NAME=""

# OR Cloudinary
# CLOUDINARY_CLOUD_NAME=""
# CLOUDINARY_API_KEY=""
# CLOUDINARY_API_SECRET=""

# Firebase (for push notifications)
# FIREBASE_PROJECT_ID=""
# FIREBASE_PRIVATE_KEY=""
# FIREBASE_CLIENT_EMAIL=""

# FUTURE: Add email service
# SENDGRID_API_KEY=""
# SMTP_HOST=""
# SMTP_PORT=""
# SMTP_USER=""
# SMTP_PASS=""

# FUTURE: Add SMS service (for OTP verification)
# TWILIO_ACCOUNT_SID=""
# TWILIO_AUTH_TOKEN=""
# TWILIO_PHONE_NUMBER=""

# FUTURE: Add monitoring
# SENTRY_DSN=""

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
