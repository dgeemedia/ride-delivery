{
  "name": "diakite-backend",
  "version": "1.0.0",
  "description": "Backend API for Diakite - Ride Hailing & Delivery Platform",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "migrate": "npx prisma migrate dev",
    "migrate:deploy": "npx prisma migrate deploy",
    "generate": "npx prisma generate",
    "seed": "node prisma/seed.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "postinstall": "prisma generate || true"
  },
  "keywords": [
    "ride-hailing",
    "delivery",
    "nigeria",
    "paystack",
    "flutterwave"
  ],
  "author": "Diakite",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^5.9.0",
    "agora-token": "^2.0.5",
    "axios": "^1.13.6",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.9.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "firebase-admin": "^12.0.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "multer-storage-cloudinary": "4.0.0",
    "socket.io": "^4.6.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.3",
    "prisma": "^5.9.0",
    "supertest": "^7.1.3"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "protobufjs"
    ],
    "peerDependencyRules": {
      "allowedVersions": {
        "multer-storage-cloudinary>cloudinary": "2"
      }
    }
  }
}